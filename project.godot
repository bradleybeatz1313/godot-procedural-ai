; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Procedural AI Dungeon"
config/description="Procedural dungeon generation with AI-driven agents and dynamic difficulty"
config/version="1.2.0"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
EventBus="*res://scripts/core/event_bus.gd"
AIDirector="*res://scripts/ai/ai_director.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"

[layer_names]

2d_physics/layer_1="walls"
2d_physics/layer_2="agents"
2d_physics/layer_3="items"
2d_physics/layer_4="triggers"

[debug]

settings/fps/force_fps=0
gdscript/warnings/unused_variable=1
gdscript/warnings/unused_signal=1

[rendering]

renderer/rendering_method="gl_compatibility"
